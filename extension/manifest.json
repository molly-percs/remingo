{
  "manifest_version": 3,
  "name": "ReMingo",
  "version": "1.0.0",
  "description": "Rewrite a dictated email draft in your own writing style, right inside Gmail, Outlook, or any webmail.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "ReMingo"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:4318/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_origin_as_fallback": true,
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
